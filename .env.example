# HTTP port (default: 3000)
PORT=3000

# OpenAI API key (GPT-4o by default; override with OPENAI_MODEL)
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=

# Uniblock API key for ABI + source fetching
UNIBLOCK_API_KEY=

# Pinata JWT for IPFS pinning
PINATA_JWT=

# Pinata dedicated gateway domain (e.g. example-gateway.mypinata.cloud)
PINATA_GATEWAY=

# EVM wallet address to receive x402 payments (Base Mainnet)
EVM_ADDRESS=0x...

# PayAI production API keys (optional — free tier works without these)
PAYAI_API_KEY_ID=
PAYAI_API_KEY_SECRET=
